# ============================================
# Variables de Entorno - Webapp App Simple
# ============================================

# URL base de la aplicación
BASE_URL=http://localhost:3000

# Entorno (dev | staging | production)
ENV=dev

# CI flag
CI=false

# ============================================
# Oracle Database
# ============================================
DB_HOST=localhost
DB_PORT=1521
DB_SERVICE_NAME=XEPDB1
DB_USER=your_user
DB_PASSWORD=your_password

# ============================================
# Archivos Excel
# ============================================
EXCEL_DATA_PATH=./src/data/test-data.xlsx
